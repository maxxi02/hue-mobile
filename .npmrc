# Expo/Metro and RN native autolinking don't understand pnpm's default symlinked
# node_modules. Hoist so packages resolve like npm/yarn. See vault: Setup Guide (pnpm).
node-linker=hoist

# Windows path-length fix for native (CMake/ninja) builds. pnpm's default virtual
# store (node_modules/.pnpm/<pkg>@<ver>_<hash>/node_modules/<pkg>/...) pushes the
# C++ object-file paths for react-native-worklets/screens past the ~250-char limit,
# failing the build with "ninja: manifest 'build.ninja' still dirty after 100 tries".
# Relocating the store to a short root and capping the dir-name length keeps object
# paths well under the limit. See vault: Phase 1 Build Notes.
virtual-store-dir=C:/.pn
virtual-store-dir-max-length=40
